{
  "components": [
    { "id": "chat_1", "provider": "chat", "config": { "hideForm": true, "mode": "Source", "parameters": {}, "type": "chat" } },

    { "id": "agent_orchestrator", "provider": "agent_deepagent", "config": { "instructions": ["$ORCHESTRATOR_INSTRUCTIONS — delegate to the sub-agents; assemble ONE response$"], "max_waves": 10, "parameters": {} }, "input": [{ "lane": "questions", "from": "chat_1" }] },

    { "id": "agent_sub1", "provider": "agent_deepagent_subagent", "config": { "name": "$SUBAGENT_1_NAME$", "description": "$WHEN_THE_ORCHESTRATOR_SHOULD_USE_SUB1$", "instructions": ["$SUB1_INSTRUCTIONS$"], "parameters": {} }, "control": [{ "classType": "deepagent", "from": "agent_orchestrator" }] },
    { "id": "agent_sub2", "provider": "agent_deepagent_subagent", "config": { "name": "$SUBAGENT_2_NAME$", "description": "$WHEN_THE_ORCHESTRATOR_SHOULD_USE_SUB2$", "instructions": ["$SUB2_INSTRUCTIONS$"], "parameters": {} }, "control": [{ "classType": "deepagent", "from": "agent_orchestrator" }] },

    { "id": "llm_orchestrator", "provider": "llm_openai", "config": { "profile": "gpt-4-1", "gpt-4-1": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" }, "parameters": {} }, "control": [{ "classType": "llm", "from": "agent_orchestrator" }] },
    { "id": "llm_sub1", "provider": "llm_openai", "config": { "profile": "gpt-4-1", "gpt-4-1": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" }, "parameters": {} }, "control": [{ "classType": "llm", "from": "agent_sub1" }] },
    { "id": "llm_sub2", "provider": "llm_openai", "config": { "profile": "gpt-4-1-mini", "gpt-4-1-mini": { "apikey": "${ROCKETRIDE_OPENAI_KEY}" }, "parameters": {} }, "control": [{ "classType": "llm", "from": "agent_sub2" }] },

    { "id": "response_1", "provider": "response_answers", "config": { "laneName": "answers" }, "input": [{ "lane": "answers", "from": "agent_orchestrator" }] }
  ],
  "project_id": "REPLACE_WITH_LITERAL_GUID",
  "viewport": { "x": 0, "y": 0, "zoom": 1 },
  "version": 1
}
